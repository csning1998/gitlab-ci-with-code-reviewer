#!/bin/sh
# Validates local commit messages against the conventional commit specification using the
# shared reviewer container image, eliminating local Node.js dependency requirements.
# Activation command: git config core.hooksPath .githooks

set -e

IMAGE="registry.gitlab.com/csning1998/gitlab-ci-with-code-reviewer/reviewer:edge"
MSG_FILE="$1"
REPO_ROOT="$(git rev-parse --show-toplevel)"

# commitlint resolves Git repository metadata from its container working directory (/repo).
# Mounts the full repository root and projects the target commit message file into .git/
# to satisfy commitlint's relative path resolution requirements during --edit execution.
podman run --rm \
    -v "${REPO_ROOT}":/repo:Z \
    -v "$(realpath "${MSG_FILE}")":/repo/.git/COMMIT_EDITMSG_HOOK:Z \
    -w /repo \
    "$IMAGE" \
    commitlint --config /etc/commitlint/commitlint.config.cjs --edit .git/COMMIT_EDITMSG_HOOK
